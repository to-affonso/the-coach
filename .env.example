# URL do projeto Supabase (Project Settings > API)
NEXT_PUBLIC_SUPABASE_URL=

# Publishable key do projeto (Project Settings > API > Publishable key)
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Chave AES-256-GCM (32 bytes em base64) para cifrar os tokens do Garmin.
# Gerar com: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
GARMIN_ENCRYPTION_KEY=

# Secret key do projeto (Project Settings > API > Secret keys) — bypassa RLS.
# Só usada server-side (motor de sync: endpoint por usuário e cron diário).
SUPABASE_SECRET_KEY=

# Protege o endpoint do cron diário contra chamadas externas.
# Gerar com: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
CRON_SECRET=
